{
  "name": "@bitsocial/bitsocial-seeder",
  "type": "module",
  "version": "0.3.1",
  "description": "Seed Bitsocial community pages and pubsub topics through a Bitsocial CLI daemon.",
  "keywords": [
    "bitsocial",
    "pkc",
    "ipfs",
    "seeder",
    "pubsub"
  ],
  "author": "Bitsocial Forge",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=24"
  },
  "main": "start.js",
  "bin": {
    "bitsocial-seeder": "bin/bitsocial-seeder.js"
  },
  "files": [
    "bin",
    "config.js",
    "lib",
    "start.js",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "changelog": "node scripts/generate-changelog.mjs",
    "changelog:release-notes": "node scripts/changelog-release-notes.mjs",
    "start": "node start.js",
    "test": "node --test"
  },
  "dependencies": {
    "@bitsocial/bitsocial-cli": "0.19.73",
    "@pkcprotocol/pkc-js": "0.0.48",
    "@russellthehippo/honker-node": "0.3.3",
    "dotenv": "16.0.3",
    "javascript-time-ago": "2.5.10",
    "kubo-rpc-client": "6.1.0",
    "string-strip-html": "13.4.8",
    "yargs": "17.7.1"
  },
  "overrides": {
    "@pkcprotocol/pkc-js": "0.0.48"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitsocialnet/bitsocial-seeder.git"
  },
  "optionalDependencies": {
    "bufferutil": "4.1.0",
    "utf-8-validate": "6.0.6"
  }
}
